{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "github": {
      "type": "local",
      "command": ["github-mcp-server", "stdio"],
      "environment": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "{file:~/repos/diricode/.github-token}",
        "GITHUB_TOOLSETS": "repos,issues,pull_requests,users,projects"
      }
    }
  }
}
