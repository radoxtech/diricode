{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ESNext",
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "strictBindCallApply": true,
    "strictPropertyInitialization": true,
    "noImplicitThis": true,
    "alwaysStrict": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noPropertyAccessFromIndexSignature": false,
    "exactOptionalPropertyTypes": false,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "composite": true,
    "incremental": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "skipLibCheck": true,
    "paths": {
      "@diricode/core": ["./packages/core/src/index.ts"],
      "@diricode/core/*": ["./packages/core/src/*"],
      "@diricode/server": ["./packages/server/src/index.ts"],
      "@diricode/server/*": ["./packages/server/src/*"],
      "@diricode/web": ["./packages/web/src/index.ts"],
      "@diricode/web/*": ["./packages/web/src/*"],
      "@diricode/memory": ["./packages/memory/src/index.ts"],
      "@diricode/memory/*": ["./packages/memory/src/*"],
      "@diricode/dirirouter": ["./packages/dirirouter/src/index.ts"],
      "@diricode/dirirouter/*": ["./packages/dirirouter/src/*"],
      "@diricode/dirirouter/contracts": ["./packages/dirirouter/src/contracts/index.ts"],
      "@diricode/dirirouter/contracts/*": ["./packages/dirirouter/src/contracts/*"],
      "@diricode/dirirouter/providers": ["./packages/dirirouter/src/providers/index.ts"],
      "@diricode/dirirouter/providers/*": ["./packages/dirirouter/src/providers/*"],
      "@diricode/dirirouter/router": ["./packages/dirirouter/src/router/index.ts"],
      "@diricode/dirirouter/router/*": ["./packages/dirirouter/src/router/*"],
      "@diricode/dirirouter/picker": ["./packages/dirirouter/src/picker/index.ts"],
      "@diricode/dirirouter/picker/*": ["./packages/dirirouter/src/picker/*"],
      "@diricode/dirirouter/feedback": ["./packages/dirirouter/src/feedback.ts"],
      "@diricode/dirirouter/feedback/*": ["./packages/dirirouter/src/*"],
      "@diricode/github-mcp": ["./packages/github-mcp/src/index.ts"],
      "@diricode/github-mcp/*": ["./packages/github-mcp/src/*"],
      "@diricode/tools": ["./packages/tools/src/index.ts"],
      "@diricode/tools/*": ["./packages/tools/src/*"],
      "@diricode/agents": ["./packages/agents/src/index.ts"],
      "@diricode/agents/*": ["./packages/agents/src/*"],
      "@diricode/cli": ["./apps/cli/src/index.ts"],
      "@diricode/cli/*": ["./apps/cli/src/*"]
    }
  }
}
